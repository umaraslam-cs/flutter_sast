# Exclude local / IDE artifacts from the published tarball (especially when
# not publishing from a git checkout). See https://dart.dev/tools/pubignore
.dart_tool/
build/
.idea/
.cursor/
*.iml
.metadata

# Local scan output (default CLI filenames)
flutter_sast_report.json
flutter_sast_report.html
example/flutter_sast_report.json
example/flutter_sast_report.html
